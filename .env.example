# ─── GitHub OAuth App ──────────────────────────────────────────────────────
# Your GitHub OAuth App Client ID (public, safe to expose)
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# Base URL of your Gatekeeper instance (https://github.com/prose/gatekeeper).
# LiteEditor will call GET <VITE_TOKEN_PROXY_URL>/<code> to exchange the OAuth
# code for an access token. The trailing slash is optional.
# Example: https://liteditor-auth.liteapp.fr/authenticate
VITE_TOKEN_PROXY_URL=https://your-gatekeeper.example.com/authenticate
