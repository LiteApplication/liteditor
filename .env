# ─── GitHub OAuth App ──────────────────────────────────────────────────────
# Your GitHub OAuth App Client ID (public, safe to expose)
VITE_GITHUB_CLIENT_ID=Ov23li8tDs4VOSU7CXle

# A small proxy server that exchanges the OAuth code for an access_token.
# GitHub's OAuth flow requires a server-side secret for the token exchange.
# You can deploy a minimal proxy using Cloudflare Workers, Vercel Edge, etc.
# See: https://github.com/gr2m/github-oauth-login or similar.
# Example: https://github-oauth-proxy.your-domain.workers.dev/token
VITE_TOKEN_PROXY_URL=https://liteditor-auth.liteapp.fr/authenticate
